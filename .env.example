# Required: HTTP JSON-RPC URL of your EVM node (Polygon Edge, etc.).
# From the host machine (not Docker), this might be http://127.0.0.1:8545
# From inside Docker Desktop (Mac/Windows), host.docker.internal often works.
RPC_URL=http://host.docker.internal:8545

# Optional: concurrent transaction fetch workers in docker-compose (default 8; raise if your RPC can handle it).
# TX_WORKERS=8

# Optional: bounded queue for ERC-20 stats jobs in docker-compose (default 64).
# ERC20_STATS_BUFFER=64

# Optional: bounded queue for entity / adoption stats jobs in docker-compose (default 64).
# ENTITY_STATS_BUFFER=64

# Optional: Bearer token for POST /admin/v1/erc20/watchlist (register ERC-20 watchlist rows).
# If unset, that endpoint returns 404 until you set it (e.g. in Compose for the api service).
# ADMIN_API_SECRET=change-me-to-a-long-random-string
